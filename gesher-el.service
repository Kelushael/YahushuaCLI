[Unit]
Description=Gesher-el Anthropic API Bridge
After=network.target axis-model.service
Wants=axis-model.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /root/sovereign-agent/gesher.py
Environment=LLAMA_URL=http://127.0.0.1:8181
Environment=GESHER_PORT=8182
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
